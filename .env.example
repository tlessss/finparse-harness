# 复制为 .env 后填写本地值：cp .env.example .env
# PDF / goldset 不进 git，见 .gitignore

# 数据库（可选，API 直连解析可不配）
DATABASE_URL=mysql+pymysql://user:password@host:3306/caibaoxia

# LLM
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# PDF 缓存路径
PDF_CACHE_DIR=../book-agent/output/pdf_cache

# 向量库
RAG_DATA_DIR=../quantification/rag_data
RAG_MODEL_DIR=../quantification/rag_models/BAAI/bge-small-zh-v1.5

# 服务端口
PORT=8200
FRONTEND_PORT=5281

# 迭代控制
MAX_ITERATE=3
LAYOUT_SIMILARITY_THRESHOLD=0.80
SEMANTIC_SIMILARITY_THRESHOLD=0.60

# 钉钉 ↔ Claude Code 桥（tools/dingtalk_bridge/，可选）
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ALLOWED_STAFF=          # 你的 staffId，逗号分隔；务必设，否则任何人都能驱动全权限 agent
# CLAUDE_WORKDIR=/Users/admin/formal/FinParseAI
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_TIMEOUT=1800
# CLAUDE_BIN=/Users/admin/.local/bin/claude
